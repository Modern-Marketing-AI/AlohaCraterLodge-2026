modules = ["python-3.11", "nodejs-20"]
[agent]
expertMode = true

[deployment]
deploymentTarget = "static"
publicDir = "."

[nix]
channel = "stable-25_05"
packages = ["python3Minimal"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start website"

[[workflows.workflow]]
name = "Start website"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 server.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 5000

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 30000
